# ═══════════════════════════════════════════════════════════
# JOBSY V2 — Environment Variables
# Copy this to .env and fill in values from CREDENTIALS_VAULT.json
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────
# Use EXTERNAL URL for local dev, INTERNAL URL on Railway
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Auth ────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ─── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_RETURN_URL=https://jobsyja.com/payments/complete
STRIPE_REFRESH_URL=https://jobsyja.com/payments/refresh

# ─── Stream Chat ─────────────────────────────────────────
STREAM_API_KEY=
STREAM_API_SECRET=

# ─── Cloudinary ──────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=djylcabbp
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Mapbox ──────────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=
MAPBOX_SECRET_TOKEN=

# ─── Email ───────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@jobsyja.com
RESEND_API_KEY=

# ─── Twilio ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Error Tracking ─────────────────────────────────────
SENTRY_DSN=

# ─── Analytics ───────────────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
GA4_MEASUREMENT_ID=G-BRG0V4Y3G1

# ─── PayPal ──────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ─── Slack ───────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=#alerts

# ─── Firebase ────────────────────────────────────────────
FIREBASE_CREDENTIALS_JSON=

# ─── Expo ────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=

# ─── App ─────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
API_URL=http://localhost:8080
WEB_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ─── Platform ────────────────────────────────────────────
PLATFORM_COMMISSION_RATE=0.10
